{
  "permissions": {
    "allow": [
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(pkill -f \"next dev\")",
      "Bash(pnpm --filter @dailyforge/db db:seed)",
      "Bash(pnpm --filter @dailyforge/db db:seed:apps)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\" http://localhost:3000)",
      "Bash(curl -s -o /dev/null -w \" | /signin: %{http_code}\" http://localhost:3000/signin)",
      "Bash(curl -s -o /dev/null -w \" | /dashboard: %{http_code}\" http://localhost:3000/dashboard)",
      "PowerShell(Get-Process node -ErrorAction SilentlyContinue | Where-Object { $_.MainWindowTitle -eq \"\" } | Stop-Process -Force; Write-Host \"Killed node processes\")",
      "Bash(curl -s -o /dev/null -w \"/ => %{http_code}\" http://localhost:3000)",
      "Bash(curl -s -o /dev/null -w \" | /signin => %{http_code}\" http://localhost:3000/signin)",
      "Bash(curl -s -o /dev/null -w \" | /api/trpc => %{http_code}\\\\n\" http://localhost:3000/api/trpc/users.me)",
      "PowerShell(Get-Process node -ErrorAction SilentlyContinue)",
      "PowerShell(Stop-Process -Force)",
      "Bash(curl -s -o /dev/null -w \" | /api/trpc/users.me => %{http_code}\\\\n\" \"http://localhost:3000/api/trpc/users.me\")",
      "Bash(curl -s -o /dev/null -w \"/dashboard => %{http_code}\" http://localhost:3000/dashboard)",
      "Bash(curl -s -o /dev/null -w \" | /store => %{http_code}\" http://localhost:3000/store)",
      "Bash(curl -s -o /dev/null -w \" | /apps/todo => %{http_code}\\\\n\" http://localhost:3000/apps/todo)",
      "Bash(pnpm --filter @dailyforge/web dlx shadcn@latest add label --yes)",
      "Bash(pnpm dlx *)",
      "Bash(pnpm --filter @dailyforge/db exec prisma generate)",
      "Bash(pnpm --filter @dailyforge/db exec prisma db push)",
      "Bash(pnpm --filter @dailyforge/db exec prisma generate --force)",
      "Bash(node_modules/.bin/prisma db *)",
      "Bash(node_modules/.bin/prisma generate *)",
      "Bash(pnpm add *)",
      "Bash(pnpm --filter @dailyforge/db exec prisma db push --accept-data-loss)"
    ]
  }
}
