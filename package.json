{
  "name": "dailyforge",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\" --ignore-path .gitignore"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/engines", "prisma", "sharp", "unrs-resolver"]
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
